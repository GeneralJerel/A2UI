{
  "name": "Financial Data Grid",
  "description": "Demonstrates layout weighting and alignment using Rows and Columns with templates.",
  "messages": [
    {
      "version": "v0.9",
      "createSurface": {
        "surfaceId": "gallery-financial-grid",
        "catalogId": "https://a2ui.org/specification/v0_9/basic_catalog.json",
        "sendDataModel": true
      }
    },
    {
      "version": "v0.9",
      "updateComponents": {
        "surfaceId": "gallery-financial-grid",
        "components": [
          {
            "id": "root",
            "component": "Card",
            "child": "main-column"
          },
          {
            "id": "main-column",
            "component": "Column",
            "children": [
              "header-row",
              "grid-list"
            ],
            "align": "stretch"
          },
          {
            "id": "header-row",
            "component": "Row",
            "children": [
              "col-asset",
              "col-price",
              "col-change"
            ],
            "align": "center"
          },
          {
            "id": "col-asset",
            "component": "Text",
            "text": "Asset",
            "variant": "caption",
            "weight": 1.5
          },
          {
            "id": "col-price",
            "component": "Text",
            "text": "Price",
            "variant": "caption",
            "weight": 1.5
          },
          {
            "id": "col-change",
            "component": "Text",
            "text": "Change",
            "variant": "caption",
            "weight": 1
          },
          {
            "id": "grid-list",
            "component": "List",
            "children": {
              "path": "/assets",
              "componentId": "row-template"
            }
          },
          {
            "id": "row-template",
            "component": "Row",
            "children": [
              "asset-name",
              "asset-price",
              "asset-change"
            ],
            "align": "center"
          },
          {
            "id": "asset-name",
            "component": "Text",
            "text": { "path": "name" },
            "weight": 1.5
          },
          {
            "id": "asset-price",
            "component": "Text",
            "text": { "path": "price" },
            "weight": 1.5
          },
          {
            "id": "asset-change",
            "component": "Text",
            "text": { "path": "change" },
            "weight": 1
          }
        ]
      }
    },
    {
      "version": "v0.9",
      "updateDataModel": {
        "surfaceId": "gallery-financial-grid",
        "value": {
          "assets": [
            { "name": "Bitcoin", "price": "$43,500", "change": "+1.2%" },
            { "name": "Ethereum", "price": "$2,250", "change": "-0.5%" },
            { "name": "Solana", "price": "$95.80", "change": "+5.4%" }
          ]
        }
      }
    }
  ]
}
